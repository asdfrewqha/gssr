# Env files with secrets (commit only .env.example, never .env)
.env
.env.local
*.env.local
services/game/.env
services/workers/.env
frontend/.env
admin/.env
infra/compose/.env

# LiveKit config — written by CI deploy script, contains API keys
infra/compose/livekit.yaml

# HTTP Basic Auth for /utils/ admin routes — generated from ADMIN_USERNAME/ADMIN_PASSWORD
# echo "$ADMIN_USERNAME:$(openssl passwd -apr1 "$ADMIN_PASSWORD")" > infra/nginx/utils.htpasswd
infra/nginx/utils.htpasswd

# Go
services/game/dist/
services/game/coverage.out

# Python
services/workers/__pycache__/
services/workers/**/__pycache__/
services/workers/.pytest_cache/
services/workers/.coverage
services/workers/models/     # NSFW model binary (~50MB)

# Node
node_modules/
.prettier-caches/
frontend/dist/
frontend/coverage/
admin/dist/

# Cloudflare tunnel credentials (contains private key)
infra/cloudflare/credentials.json

# k3s kubeconfig
*.kubeconfig

