# LiveKit server configuration
# Copy to livekit.yaml and fill in your API key/secret.
# In production, livekit.yaml is written by the CI deploy script — do not commit it.

port: 7880
rtc:
  port_range_start: 50000
  port_range_end: 60000
  tcp_port: 7881

# API key → API secret mapping
# Must match LIVEKIT_API_KEY / LIVEKIT_API_SECRET in .env
keys:
  devkey: devsecret

logging:
  level: info
