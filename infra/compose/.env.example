# === Postgres ===
POSTGRES_USER=gssr
POSTGRES_PASSWORD=changeme
POSTGRES_DB=gssr
DATABASE_URL=postgres://gssr:changeme@postgres:5432/gssr

# === Valkey (Redis-compatible) ===
VALKEY_URL=redis://valkey:6379

# === RabbitMQ ===
RABBITMQ_USER=gssr
RABBITMQ_PASS=changeme
RABBITMQ_URL=amqp://gssr:changeme@rabbitmq:5672/

# === MinIO S3 ===
MINIO_ROOT_USER=gssr
MINIO_ROOT_PASSWORD=changeme
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=gssr

# === Auth ===
JWT_SECRET=replace-with-64-char-random-string
JWT_ACCESS_TTL=4h
JWT_REFRESH_TTL=720h

# === LiveKit ===
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=your-livekit-key
LIVEKIT_API_SECRET=your-livekit-secret

# === Workers ===
NSFW_MODEL_PATH=/app/models/nsfw.onnx
NSFW_THRESHOLD=0.7
WORKERS_DATABASE_URL=postgresql+asyncpg://gssr:changeme@postgres:5432/gssr

# === Admin (first admin seeded from these at startup) ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# === SMTP (optional — email verification) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@gssr.school
FRONTEND_URL=https://school.example.com

# === Monitoring ===
GRAFANA_PASSWORD=changeme
DOMAIN=school.example.com

# === DockerHub ===
DOCKERHUB_USERNAME=yourdockeruser
