# admin — React admin panel
# Copy to .env and fill in values for local development.

# In dev, leave VITE_API_BASE empty — vite proxy handles routing.
# In production (Cloudflare Pages), set to the backend origin e.g. https://domain.com
VITE_API_BASE=

# Dev proxy targets (used by vite.config.ts process.env, not VITE_ prefix)
# These are NOT exposed to the browser bundle.
VITE_GAME_URL=http://localhost:3000
VITE_WORKERS_URL=http://localhost:8000

# MinIO public URL for previewing panorama tiles and floor images
VITE_MINIO_URL=http://localhost:9000/gssr
